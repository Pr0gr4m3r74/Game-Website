{
  "name": "avatar3d-social-platform",
  "version": "0.1.0",
  "description": "3D Avatar Social Game Platform - Web, iOS, Android PWA",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:desktop": "pnpm run build:electron && concurrently -k \"pnpm --filter frontend dev\" \"wait-on http://localhost:3000 && cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron dist-electron/main.js\"",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:desktop": "pnpm run build:frontend && pnpm run build:electron",
    "dist:desktop": "pnpm run build:desktop && electron-builder --win",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter backend test:e2e",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "pnpm --filter backend migrate",
    "db:seed": "pnpm --filter backend seed"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.gamewebsite.desktop",
    "productName": "Game Website",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "apps/frontend/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "apps/frontend/public/icons/icon-512x512.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
